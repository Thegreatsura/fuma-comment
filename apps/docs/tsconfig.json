{
	"extends": "tsconfig/nextjs.json",
	"compilerOptions": {
		"paths": {
			"@/*": ["./*"],
			"fumadocs-mdx:collections/*": ["./.source/*"]
		},
		"target": "esnext",
		"plugins": [{ "name": "next" }]
	},
	"include": ["next-env.d.ts", "**/*.ts", "**/*.tsx", ".next/types/**/*.ts"],
	"exclude": ["node_modules"]
}
